# OAuth client credentials baked into local builds via `task build`.
# Copy to .env and fill in (a Google "Desktop app" OAuth client).
# The .env file is gitignored. To generate it from a downloaded client_secret
# JSON:
#
#   f=client_secret_*.json
#   echo "GOOGLE_OAUTH_CLIENT_ID=$(jq -r .installed.client_id $f)"      > .env
#   echo "GOOGLE_OAUTH_CLIENT_SECRET=$(jq -r .installed.client_secret $f)" >> .env
#
# Leaving these empty just builds a binary without embedded credentials
# (fine for development; users then supply credentials_path themselves).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
